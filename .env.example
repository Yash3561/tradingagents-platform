# ── Database ──────────────────────────────────────────────
# Local Docker: use defaults below
# Free tier: paste your Neon connection string as DATABASE_URL directly
POSTGRES_USER=tap
POSTGRES_PASSWORD=tap_secret
POSTGRES_DB=trading

# Neon free tier (alternative to local Postgres):
# DATABASE_URL=postgresql+asyncpg://user:pass@ep-xxx.neon.tech/trading?ssl=require

# ── Broker ────────────────────────────────────────────────
ALPACA_API_KEY=your_alpaca_key
ALPACA_API_SECRET=your_alpaca_secret
ALPACA_BASE_URL=https://paper-api.alpaca.markets   # paper trading (safe default)
ALPACA_DATA_URL=https://data.alpaca.markets

# ── LLM ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_key
NVIDIA_API_KEY=your_nvidia_nim_key    # get free at build.nvidia.com
LLM_PROVIDER=nvidia
LLM_MODEL=deepseek-ai/deepseek-v4-flash

# ── Agent Config ──────────────────────────────────────────
AGENT_DEBATE_ROUNDS=2
AGENT_MAX_RISK_DISCUSSIONS=2
AGENT_ONLINE_TOOLS=true

# ── App ───────────────────────────────────────────────────
# SECRET_KEY signs JWTs AND encrypts stored broker keys — set once, never rotate
# casually (rotating forces every user to reconnect their broker).
SECRET_KEY=change_this_in_production
ENVIRONMENT=development
LOG_LEVEL=INFO

# Gate public signups: when set, new accounts require this code
# (admin-issued invite codes from the Admin page also work)
SIGNUP_INVITE_CODE=

# This email is auto-promoted to admin on signup/login
ADMIN_EMAIL=

# Outbound email for password reset / verification links.
# Leave SMTP_HOST empty to log links to the backend log instead (dev mode).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Public frontend URL — used in emailed links and CORS
FRONTEND_URL=
# In production, CORS allows ONLY FRONTEND_URL. Set true to also allow
# *.vercel.app preview deploys (admits any Vercel-hosted site — use sparingly).
CORS_ALLOW_VERCEL_PREVIEWS=false

# ── Deployment shape (see DEPLOY.md) ─────────────────────
# true = worker loops run inside the API process (single-container free deploys)
RUN_ALL_WORKERS=false
# false = skip Alpaca tick stream (protects Upstash free-tier Redis quota)
PRICE_FEED_ENABLED=true
